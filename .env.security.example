# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# This file contains security-related environment variables
# for the AIG-App application.
#
# IMPORTANT: Copy these to your .env file and adjust for your environment

# ===========================================
# SESSION SECURITY
# ===========================================

# Session Driver
# Options: file, cookie, database, memcached, redis, dynamodb, array
SESSION_DRIVER=database

# Session Lifetime (in minutes)
SESSION_LIFETIME=120

# Encrypt Session Data
# Set to true to encrypt all session data before storing
# IMPORTANT: Enable this in production for sensitive data
SESSION_ENCRYPT=true

# Secure Cookie (HTTPS Only)
# Set to true to only send session cookies over HTTPS
# IMPORTANT: Must be true in production
# Set to false in local development (http://localhost)
SESSION_SECURE_COOKIE=true

# Session Domain
# Set this to your application domain for proper cookie scope
# Examples:
#   - .example.com (works for all subdomains)
#   - example.com (main domain only)
#   - Leave empty for current domain
SESSION_DOMAIN=

# HTTP Only Cookies
# Prevents JavaScript from accessing session cookies (XSS protection)
# IMPORTANT: Always keep this true
SESSION_HTTP_ONLY=true

# SameSite Cookie Attribute
# Options: lax, strict, none, null
# - lax: Balance between security and usability (recommended)
# - strict: Maximum security (may break some cross-site features)
# - none: Required for cross-site requests (requires HTTPS)
SESSION_SAME_SITE=lax

# Session Expire on Close
# Set to true to expire session when browser closes
SESSION_EXPIRE_ON_CLOSE=false

# Session Path
# Path on the server where the cookie will be available
SESSION_PATH=/

# Session Cookie Name
# Name of the session cookie
# Will be prefixed with app name if not set
SESSION_COOKIE=

# Session Connection
# Database connection to use for session storage (if using database driver)
SESSION_CONNECTION=

# Session Table
# Table name for session storage (if using database driver)
SESSION_TABLE=sessions

# Session Store
# Cache store to use (if using cache-based session driver)
SESSION_STORE=

# ===========================================
# CSRF PROTECTION
# ===========================================

# CSRF tokens are enabled by default in Laravel
# No configuration needed, but ensure your forms include @csrf directive

# ===========================================
# COOKIE SECURITY
# ===========================================

# Cookie Path
COOKIE_PATH=/

# Cookie Domain
COOKIE_DOMAIN=

# Secure Cookies (HTTPS Only)
# IMPORTANT: Must be true in production
COOKIE_SECURE=true

# HTTP Only Cookies
COOKIE_HTTP_ONLY=true

# SameSite Cookies
COOKIE_SAME_SITE=lax

# ===========================================
# CORS CONFIGURATION
# ===========================================

# Allowed CORS Origins
# Comma-separated list of allowed origins
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Allow All Origins (Development Only)
# IMPORTANT: Never set to * in production
CORS_ALLOW_ALL_ORIGINS=false

# Allowed Methods
CORS_ALLOWED_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"

# Allowed Headers
CORS_ALLOWED_HEADERS="Content-Type,Authorization,X-Requested-With,X-CSRF-TOKEN"

# Expose Headers
CORS_EXPOSED_HEADERS=

# Max Age (in seconds)
CORS_MAX_AGE=0

# Support Credentials
CORS_SUPPORTS_CREDENTIALS=true

# ===========================================
# CONTENT SECURITY POLICY (CSP)
# ===========================================

# Enable CSP Headers
CSP_ENABLED=true

# CSP Report Only Mode (for testing)
CSP_REPORT_ONLY=false

# CSP Directives
CSP_DEFAULT_SRC="'self'"
CSP_SCRIPT_SRC="'self' 'unsafe-inline' 'unsafe-eval'"
CSP_STYLE_SRC="'self' 'unsafe-inline'"
CSP_IMG_SRC="'self' data: https:"
CSP_FONT_SRC="'self' data:"
CSP_CONNECT_SRC="'self'"
CSP_FRAME_ANCESTORS="'self'"

# ===========================================
# PASSWORD SECURITY
# ===========================================

# Password Minimum Length
PASSWORD_MIN_LENGTH=8

# Require Password Confirmation Timeout (in seconds)
# Time before password confirmation is required again
PASSWORD_TIMEOUT=10800

# ===========================================
# RATE LIMITING
# ===========================================

# Throttle Max Attempts
THROTTLE_MAX_ATTEMPTS=60

# Throttle Decay Minutes
THROTTLE_DECAY_MINUTES=1

# Login Throttle Max Attempts
LOGIN_MAX_ATTEMPTS=5

# Login Throttle Decay Minutes
LOGIN_DECAY_MINUTES=1

# ===========================================
# TWO-FACTOR AUTHENTICATION
# ===========================================

# Enable 2FA
TWO_FACTOR_ENABLED=true

# 2FA QR Code Size
TWO_FACTOR_QR_CODE_SIZE=200

# ===========================================
# API SECURITY
# ===========================================

# API Rate Limit (requests per minute)
API_RATE_LIMIT=60

# API Throttle Decay Minutes
API_THROTTLE_DECAY=1

# Sanctum Stateful Domains
# Comma-separated list of domains that can make stateful API requests
# Example: localhost,127.0.0.1,example.com,*.example.com
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Sanctum Cookie Name
SANCTUM_COOKIE_NAME=aig_app_session

# ===========================================
# TRUSTED PROXIES
# ===========================================

# Trusted Proxies
# Comma-separated list of proxy IP addresses to trust
# Use * to trust all proxies (not recommended for production)
TRUSTED_PROXIES=

# Trusted Hosts
# Comma-separated list of trusted hostnames
TRUSTED_HOSTS=

# ===========================================
# SECURITY HEADERS
# ===========================================

# X-Frame-Options
# Options: DENY, SAMEORIGIN, ALLOW-FROM https://example.com
X_FRAME_OPTIONS=SAMEORIGIN

# X-Content-Type-Options
# Prevents MIME type sniffing
X_CONTENT_TYPE_OPTIONS=nosniff

# X-XSS-Protection
# Enable XSS filtering (legacy browsers)
X_XSS_PROTECTION="1; mode=block"

# Referrer-Policy
# Options: no-referrer, no-referrer-when-downgrade, origin, origin-when-cross-origin,
#          same-origin, strict-origin, strict-origin-when-cross-origin, unsafe-url
REFERRER_POLICY=strict-origin-when-cross-origin

# ===========================================
# FILE UPLOAD SECURITY
# ===========================================

# Max Upload File Size (in kilobytes)
MAX_FILE_SIZE=102400

# Allowed File Types (comma-separated MIME types)
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# Allowed Image Types
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/gif,image/webp"

# Allowed Video Types
ALLOWED_VIDEO_TYPES="video/mp4,video/quicktime,video/x-msvideo"

# ===========================================
# NOTES FOR DIFFERENT ENVIRONMENTS
# ===========================================

# LOCAL DEVELOPMENT (http://localhost)
# SESSION_ENCRYPT=false
# SESSION_SECURE_COOKIE=false
# COOKIE_SECURE=false
# CORS_ALLOW_ALL_ORIGINS=true (with caution)

# STAGING ENVIRONMENT (https://staging.example.com)
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN=.example.com
# COOKIE_SECURE=true
# CORS_ALLOWED_ORIGINS=https://staging.example.com

# PRODUCTION ENVIRONMENT (https://example.com)
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN=.example.com
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict or lax
# CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
# CSP_ENABLED=true
# TWO_FACTOR_ENABLED=true

# ===========================================
# SECURITY CHECKLIST
# ===========================================
# Before deploying to production, ensure:
# [ ] SESSION_ENCRYPT=true
# [ ] SESSION_SECURE_COOKIE=true
# [ ] SESSION_HTTP_ONLY=true
# [ ] SESSION_DOMAIN is correctly set
# [ ] COOKIE_SECURE=true
# [ ] CORS_ALLOW_ALL_ORIGINS=false
# [ ] CORS_ALLOWED_ORIGINS lists only your domains
# [ ] CSP_ENABLED=true
# [ ] TRUSTED_PROXIES is correctly configured
# [ ] API_RATE_LIMIT is set appropriately
# [ ] TWO_FACTOR_ENABLED=true (if applicable)
# [ ] All security headers are configured
# [ ] HTTPS is enforced
# [ ] Firewall rules are in place
# [ ] Monitoring and logging are active
