# ===========================================
# PERFORMANCE OPTIMIZATION CONFIGURATION
# ===========================================

# Cache Configuration
CACHE_STORE=redis  # Use Redis for better performance (was: database)
REDIS_CLIENT=phpredis  # Use PHP extension for best performance
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_PREFIX=aig_app_

# Session Configuration
SESSION_DRIVER=redis  # Use Redis for session storage (was: database)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue Configuration
QUEUE_CONNECTION=redis  # Use Redis for queues (was: database)

# Database Query Optimization
DB_SLOW_QUERY_LOG=true
DB_SLOW_QUERY_TIME=100  # Log queries slower than 100ms

# Laravel Debugbar (Development Only)
DEBUGBAR_ENABLED=true  # Set to false in production

# Query Detector (Development Only)
QUERY_DETECTOR_ENABLED=true  # Set to false in production
QUERY_DETECTOR_THRESHOLD=1  # Alert on queries per request

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true
SLOW_REQUEST_THRESHOLD=1000  # milliseconds
SLOW_QUERY_THRESHOLD=100  # milliseconds
HIGH_MEMORY_THRESHOLD=128  # MB

# Opcache (Production)
OPCACHE_ENABLE=1
OPCACHE_ENABLE_CLI=0
OPCACHE_MEMORY_CONSUMPTION=256
OPCACHE_MAX_ACCELERATED_FILES=20000
OPCACHE_VALIDATE_TIMESTAMPS=0  # Set to 0 in production for best performance

# Caching Strategies
CACHE_QUERY_RESULTS=true
CACHE_VIEWS=true
CACHE_ROUTES=true
CACHE_CONFIG=true
CACHE_EVENTS=true

# Response Caching
RESPONSE_CACHE_ENABLED=false
RESPONSE_CACHE_LIFETIME=3600  # seconds

# Image Optimization
IMAGE_CACHE_ENABLED=true
IMAGE_WEBP_ENABLED=true
IMAGE_COMPRESSION_QUALITY=85

# Asset Optimization
VITE_BUILD_MINIFY=true
VITE_BUILD_SOURCEMAPS=false  # Disable in production

# Database Connection Pooling
DB_POOL_MIN=2
DB_POOL_MAX=20
