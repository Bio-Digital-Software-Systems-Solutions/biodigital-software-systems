# ===========================================
# MONITORING & APM CONFIGURATION
# ===========================================

# General APM Settings
APM_ENABLED=false
METRICS_ENABLED=true

# ===========================================
# NEW RELIC CONFIGURATION
# ===========================================
NEWRELIC_ENABLED=false
NEWRELIC_APP_NAME="${APP_NAME} ${APP_ENV}"
NEWRELIC_LICENSE_KEY=your_newrelic_license_key_here
NEWRELIC_TRANSACTION_TRACER_ENABLED=true
NEWRELIC_ERROR_COLLECTOR_ENABLED=true
NEWRELIC_DISTRIBUTED_TRACING_ENABLED=true

# Performance Thresholds
NEWRELIC_TRANSACTION_THRESHOLD=0.5
NEWRELIC_SLOW_SQL_THRESHOLD=0.1

# ===========================================
# DATADOG CONFIGURATION
# ===========================================
DATADOG_ENABLED=false
DATADOG_APP_NAME="${APP_NAME}"
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_AGENT_HOST=localhost
DATADOG_AGENT_PORT=8126
DATADOG_ENV="${APP_ENV}"
DATADOG_VERSION="${APP_VERSION}"
DATADOG_SERVICE="${APP_NAME}-backend"
DATADOG_DISTRIBUTED_TRACING=true
DATADOG_SAMPLING_RATE=1.0

# ===========================================
# CUSTOM METRICS CONFIGURATION
# ===========================================
METRICS_SLOW_QUERY_THRESHOLD=100
METRICS_SLOW_REQUEST_THRESHOLD=1000
METRICS_HIGH_MEMORY_THRESHOLD=128

# ===========================================
# HEALTH CHECK CONFIGURATION
# ===========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
BACKUP_NAME="${APP_NAME}"
BACKUP_INCLUDE_FILES=true
BACKUP_INCLUDE_DATABASE=true
BACKUP_COMPRESSION_METHOD=gzip
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_PASSWORD=

# Backup Notifications
BACKUP_NOTIFICATION_MAIL=admin@example.com
BACKUP_SLACK_WEBHOOK=
BACKUP_DISCORD_WEBHOOK=

# Backup Destination
BACKUP_DISK=local

# Backup Retention Policy
BACKUP_KEEP_ALL_DAYS=7
BACKUP_KEEP_DAILY_BACKUPS=14
BACKUP_KEEP_WEEKLY_BACKUPS=8
BACKUP_KEEP_MONTHLY_BACKUPS=12
BACKUP_KEEP_YEARLY_BACKUPS=5

# ===========================================
# CLOUD STORAGE FOR BACKUPS
# ===========================================

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_BACKUP_BUCKET=your-backup-bucket
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_KEY_FILE=
GOOGLE_CLOUD_STORAGE_BUCKET=

# DigitalOcean Spaces (uses S3 driver)
# AWS_ACCESS_KEY_ID=your_spaces_key
# AWS_SECRET_ACCESS_KEY=your_spaces_secret
# AWS_DEFAULT_REGION=nyc3
# AWS_BUCKET=your-space-name
# AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ===========================================
# TELESCOPE CONFIGURATION
# ===========================================
TELESCOPE_ENABLED=true
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
TELESCOPE_STORAGE_RETENTION_HOURS=48

# ===========================================
# LOG CHANNEL FOR MONITORING
# ===========================================
# Add this to config/logging.php channels:
# 'monitoring' => [
#     'driver' => 'single',
#     'path' => storage_path('logs/monitoring.log'),
#     'level' => env('LOG_LEVEL', 'debug'),
# ],
